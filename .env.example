# ============================================
# School Fees Management System - Environment
# ============================================
# Copy this file to .env and fill in real values.
# Never commit .env to source control.

# --- Postgres ---
DB_USER=sms_user
DB_PASSWORD=sms_password
DB_NAME=school_fees
DB_HOST=postgres
DB_PORT=5432

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@school.local
PGADMIN_DEFAULT_PASSWORD=admin

# --- Django backend ---
DJANGO_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
JWT_SECRET=change-me-too-for-jwt-signing
ML_SERVICE_URL=http://ml-service:8000
REDIS_URL=redis://redis:6379/0

# --- Celery (background tasks; defaults to REDIS_URL if unset) ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
# How long a payment intent may stay pending before being auto-expired.
PAYMENT_INTENT_EXPIRY_MINUTES=30

# Bootstrap superuser (created on first migrate)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@school.local
DJANGO_SUPERUSER_PASSWORD=admin

# --- Campay (mobile money) ---
# Sandbox: https://demo.campay.net  Production: https://www.campay.net  (free sandbox)
# Auth option A: app username/password (exchanged for a token automatically).
# Auth option B: a permanent CAMPAY_API_KEY (takes priority if set).
# Leave ALL blank to run in stub mode (admin simulates the callback).
CAMPAY_BASE_URL=https://demo.campay.net
CAMPAY_USERNAME=
CAMPAY_PASSWORD=
CAMPAY_API_KEY=
CAMPAY_WEBHOOK_SECRET=
# Public URL Campay POSTs status to (register in the Campay dashboard):
# CAMPAY_WEBHOOK_URL=https://<your-domain>/api/payments/webhooks/campay/

# --- Frontend (build-time) ---
VITE_API_URL=http://localhost:5000/api

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
