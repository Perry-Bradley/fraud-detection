# ============================================
# School Fees Management System - Environment
# ============================================
# Copy this file to .env and fill in real values.
# Never commit .env to source control.

# --- Postgres ---
DB_USER=sms_user
DB_PASSWORD=sms_password
DB_NAME=school_fees
DB_HOST=postgres
DB_PORT=5432

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@school.local
PGADMIN_DEFAULT_PASSWORD=admin

# --- Django backend ---
DJANGO_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
JWT_SECRET=change-me-too-for-jwt-signing
ML_SERVICE_URL=http://ml-service:8000
REDIS_URL=redis://redis:6379/0

# Bootstrap superuser (created on first migrate)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@school.local
DJANGO_SUPERUSER_PASSWORD=admin

# --- Campay (mobile money) ---
# Sandbox: https://demo.campay.net/api  Production: https://campay.net/api
# Get an API token at https://www.campay.net (sandbox is free)
CAMPAY_BASE_URL=https://demo.campay.net/api
CAMPAY_API_KEY=
CAMPAY_WEBHOOK_SECRET=

# --- Frontend (build-time) ---
VITE_API_URL=http://localhost:5000/api

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
